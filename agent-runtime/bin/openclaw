#!/usr/bin/env sh

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
PKG_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)

if [ -x "$PKG_DIR/node_modules/.bin/tsx" ]; then
  TSX_BIN="$PKG_DIR/node_modules/.bin/tsx"
elif [ -x "$PKG_DIR/../../.bin/tsx" ]; then
  TSX_BIN="$PKG_DIR/../../.bin/tsx"
else
  TSX_BIN="${OPENCLAW_TSX_BIN:-tsx}"
fi

exec "$TSX_BIN" "$SCRIPT_DIR/openclaw.ts" "$@"
