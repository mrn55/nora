{
  "name": "openclaw-e2e",
  "private": true,
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:report": "npx playwright show-report",
    "test:real": "BASE_URL=${BASE_URL:-http://localhost:8080} npx playwright test specs/real-deploy-matrix.spec.js specs/real-integrations.spec.js specs/real-channels.spec.js",
    "test:real:matrix": "BASE_URL=${BASE_URL:-http://localhost:8080} npx playwright test specs/real-deploy-matrix.spec.js",
    "test:real:integrations": "BASE_URL=${BASE_URL:-http://localhost:8080} npx playwright test specs/real-integrations.spec.js",
    "test:real:channels": "BASE_URL=${BASE_URL:-http://localhost:8080} npx playwright test specs/real-channels.spec.js",
    "capture:operator-readme": "node ./scripts/capture-operator-screenshots.mjs",
    "smoke:k8s-kind": "bash ./scripts/run-kind-k8s-smoke.sh",
    "smoke:dashboard-runtime": "node ./scripts/dashboard-runtime-smoke.mjs",
    "smoke:runtime-path": "node ./scripts/runtime-path-smoke.mjs"
