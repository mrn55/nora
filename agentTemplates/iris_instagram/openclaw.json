{
  "$schema": "https://openclaw.ai/schema/config.v1.json",
  "version": "1.0",

  "channels": {
    "_comment": "Connect messaging providers from this agent's Nora Integrations tab after installing the template."
  },

  "agents": {
    "list": [
      {
        "id": "iris",
        "name": "Iris",
        "role": "instagram-manager",
        "workspace": "~/.openclaw/workspaces/iris-instagram",
        "provider": "anthropic",
        "model": "claude-opus-4-7",
        "temperature": 0.6,
        "routines": {
          "lowTemp": {
            "model": "claude-sonnet-4-6",
            "temperature": 0.2,
            "useFor": ["analytics-pull", "summary", "classification"]
          }
        },
        "skills": [
          "instagram-graph-read",
          "instagram-graph-insights",
          "meta-business-suite-scheduler",
          "web-fetch",
          "web-search",
          "telegram-send",
          "file-read",
          "file-write"
        ],
        "deniedSkills": [
          "instagram-post-publish",
          "instagram-dm-send",
          "instagram-comment-reply",
          "instagram-follow",
          "instagram-unfollow",
          "instagram-like"
        ],
        "bindings": [],
        "notes": "Publishing and engagement skills are denied as standing permissions. Operator publishes manually or grants one-time permission per action."
      }
    ]
  },

  "scheduler": {
    "enabled": true,
    "timezone": "America/Chicago",
    "heartbeatFile": "HEARTBEAT.md"
  },

  "security": {
    "treatToolOutputAsUntrusted": true,
    "requireConfirmationFor": [
      "post-social",
      "send-dm",
      "reply-comment",
      "change-bio",
      "change-profile",
      "follow-account",
      "unfollow-account"
    ],
    "secretsProvider": "nora-integrations",
    "redactInLogs": ["access_token", "api_key", "client_secret", "bearer", "password"]
  },

  "memory": {
    "dailyFilePattern": "memory/YYYY-MM-DD.md",
    "longTermFile": "MEMORY.md",
    "pruneAfterDays": 120,
    "digestWeeklyOn": "sunday"
  }
}
